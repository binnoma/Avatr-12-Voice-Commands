<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>أوامر سيارة أفاتار</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --blue: #00d4ff;
            --blue2: #0099ff;
            --dark: #070b14;
            --card: rgba(255,255,255,0.08); /* زيادة وضوح البطاقات قليلاً */
            --border: rgba(0,212,255,0.18);
            --text: #ffffff;
            --sub: #7a9ab8;
            --active: rgba(0,212,255,0.22);
            --glow: 0 0 24px rgba(0,212,255,0.35);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--dark);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            /* إضافة صورة أفاتار 12 */
            background-image: url('https://z-cdn-media.chatglm.cn/files/0944fd50-54e2-453a-b9e8-0b4d3d1cad65.png?auth_key=1876386726-4ed68c38f0cd41ce83dd583bd571af3e-0-97802aadd270593ef8a0ba8d6d620227');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        /* خلفية متحركة مع طبقة تغميق قوية */
        .bg-lines {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
        }
        
        /* التعديل الأساسي هنا: زيادة سماكة الطبقة السوداء لتعتيم الصورة */
        .bg-lines::before {
            content: '';
            position: absolute;
            inset: 0;
            /* الطبقة الداكنة الأساسية (للتعتيم) */
            background-color: rgba(10, 15, 25, 0.92); 
            /* تدرجات الألوان الزرقاء للتأثير الجمالي فوق الطبقة السوداء */
            background-image: 
                radial-gradient(ellipse 600px 400px at 20% 30%, rgba(0,100,200,0.15) 0%, transparent 70%),
                radial-gradient(ellipse 400px 300px at 80% 70%, rgba(0,200,255,0.1) 0%, transparent 70%);
        }

        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: 
                linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        /* هيدر */
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(7,11,20,0.95); /* زيادة الشفافية قليلاً */
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 14px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            display: flex;
            flex-direction: column;
        }

        .logo h1 {
            font-size: 1.25rem;
            font-weight: 900;
            background: linear-gradient(90deg, #00d4ff, #0099ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1.1;
        }

        .logo p {
            font-size: 0.7rem;
            color: var(--sub);
            margin-top: 2px;
        }

        .car-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 0.75rem;
            color: var(--blue);
            font-weight: 700;
        }

        /* زر التفعيل */
        .wake-section {
            padding: 28px 20px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 16px;
            position: relative;
            z-index: 1;
        }

        .wake-btn {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(0,100,200,0.2));
            border: 2px solid var(--blue);
            color: var(--blue);
            font-size: 2.2rem;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            box-shadow: var(--glow), inset 0 0 20px rgba(0,212,255,0.05);
            transition: all 0.2s ease;
            position: relative;
        }

        .wake-btn::before {
            content: '';
            position: absolute;
            inset: -8px;
            border-radius: 50%;
            border: 1px solid rgba(0,212,255,0.2);
            animation: pulse-ring 2s infinite;
        }
        .wake-btn::after {
            content: '';
            position: absolute;
            inset: -16px;
            border-radius: 50%;
            border: 1px solid rgba(0,212,255,0.1);
            animation: pulse-ring 2s infinite 0.5s;
        }

        @keyframes pulse-ring {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(1.3); opacity: 0; }
        }

        .wake-btn:active {
            transform: scale(0.9);
            background: rgba(0,212,255,0.25);
        }

        .wake-btn span {
            font-size: 0.65rem;
            color: white;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .wake-info {
            text-align: center;
        }
        .wake-info h2 { font-size: 1rem; font-weight: 700; }
        .wake-info p { font-size: 0.78rem; color: var(--sub); margin-top: 3px; }

        /* تبويبات الأقسام */
        .tabs-wrapper {
            padding: 0 16px;
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

        .tabs {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 6px;
            scrollbar-width: none;
        }
        .tabs::-webkit-scrollbar { display: none; }

        .tab-btn {
            flex-shrink: 0;
            background: var(--card);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 7px 14px;
            color: var(--sub);
            font-family: 'Tajawal', sans-serif;
            font-size: 0.78rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .tab-btn.active, .tab-btn:active {
            background: rgba(0,212,255,0.15);
            border-color: var(--blue);
            color: var(--blue);
            box-shadow: 0 0 12px rgba(0,212,255,0.2);
        }

        /* المحتوى */
        .content {
            padding: 0 16px 110px;
            position: relative;
            z-index: 1;
        }

        .section {
            display: none;
        }
        .section.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
            padding-right: 12px;
            border-right: 3px solid var(--blue);
        }

        .section-title i { color: var(--blue); font-size: 1rem; }
        .section-title span { font-size: 1rem; font-weight: 900; }

        /* شبكة الأوامر */
        .cmd-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 10px;
        }

        @media (min-width: 400px) {
            .cmd-grid { grid-template-columns: repeat(4, 1fr); }
        }

        /* بطاقة الأمر */
        .cmd-card {
            background: var(--card);
            border: 1px solid rgba(255,255,255,0.1); /* زيادة وضوح الحدود */
            border-radius: 16px;
            padding: 14px 8px 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.18s ease;
            user-select: none;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2); /* ظل خفيف لرفع البطاقة عن الخلفية */
        }

        .cmd-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0,212,255,0.08), transparent);
            opacity: 0;
            transition: opacity 0.2s;
        }

        .cmd-card:active {
            transform: scale(0.92);
            border-color: var(--blue);
            box-shadow: var(--glow);
        }
        .cmd-card:active::before { opacity: 1; }

        .cmd-card.speaking {
            border-color: var(--blue);
            box-shadow: var(--glow);
            animation: speaking-pulse 0.6s ease;
        }

        @keyframes speaking-pulse {
            0% { transform: scale(1); }
            30% { transform: scale(0.94); }
            60% { transform: scale(1.03); }
            100% { transform: scale(1); }
        }

        .cmd-icon {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            background: rgba(0,212,255,0.1); /* زيادة وضوح خلفية الأيقونة */
            border: 1px solid rgba(0,212,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--blue);
            flex-shrink: 0;
        }

        .cmd-ar {
            font-size: 0.78rem;
            font-weight: 700;
            color: #e8f4ff;
            line-height: 1.3;
            text-shadow: 0 1px 2px rgba(0,0,0,0.5); /* ظل للنص لضمان القراءة */
        }

        .cmd-cn {
            font-size: 0.58rem;
            color: var(--sub);
            font-family: "Microsoft YaHei", "PingFang SC", sans-serif;
            line-height: 1.3;
        }

        /* إشعار النطق */
        .toast {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%) translateY(-20px);
            background: rgba(0,212,255,0.15);
            border: 1px solid var(--blue);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 10px 22px;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--blue);
            z-index: 500;
            opacity: 0;
            transition: all 0.3s ease;
            white-space: nowrap;
            max-width: 85vw;
            overflow: hidden;
            text-overflow: ellipsis;
            display: flex;
            align-items: center;
            gap: 8px;
            pointer-events: none;
            direction: ltr;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* فوتر */
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(7,11,20,0.98); /* خلفية فاطر أقوى */
            border-top: 1px solid var(--border);
            backdrop-filter: blur(20px);
            z-index: 200;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .footer-inner {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.78rem;
            color: var(--sub);
        }

        .footer-inner i { color: #ff4757; animation: hb 1.4s infinite; }
        @keyframes hb { 0%,100%{transform:scale(1)} 50%{transform:scale(1.3)} }
        .footer-inner b { color: var(--blue); }

        /* حجم الفاصل */
        .spacer { height: 20px; }
    </style>
</head>
<body>

<div class="bg-lines"><div class="bg-grid"></div></div>

<!-- هيدر -->
<header>
    <div class="logo">
        <h1>🚗 أفاتار</h1>
        <p>مساعد السيارة الصوتي</p>
    </div>
    <div class="car-badge">
        <i class="fa-solid fa-circle" style="font-size:7px;color:#00ff88;"></i>
        متصل
    </div>
</header>

<!-- زر الاستيقاظ -->
<div class="wake-section">
    <button class="wake-btn" onclick="speakAndToast('嗨，小艺', 'هي شياو يي - تفعيل المساعد')">
        <i class="fa-solid fa-microphone-lines"></i>
        <span>تفعيل</span>
    </button>
    <div class="wake-info">
        <h2>اضغط للتحدث مع السيارة</h2>
        <p>ابدأ دائماً بـ «هي شياو يي» لتفعيل المساعد</p>
    </div>
</div>

<!-- تبويبات -->
<div class="tabs-wrapper">
    <div class="tabs" id="tabs"></div>
</div>

<!-- المحتوى -->
<div class="content" id="content"></div>

<!-- الإشعار -->
<div class="toast" id="toast">
    <i class="fa-solid fa-volume-high"></i>
    <span id="toast-text"></span>
</div>

<!-- فوتر -->
<div class="footer">
    <div class="footer-inner">
        صنع بـ <i class="fa-solid fa-heart"></i> في الإمارات &nbsp;•&nbsp; <b>@binnoma</b>
    </div>
</div>

<script>
const categories = [
    {
        id: "wake",
        title: "التفعيل",
        icon: "fa-microphone",
        items: [
            { ar: "تفعيل المساعد", cn: "嗨，小艺", icon: "fa-microphone-lines" },
            { ar: "هل أنتِ هناك؟", cn: "你好，小艺", icon: "fa-comment-dots" },
            { ar: "شكراً", cn: "谢谢", icon: "fa-thumbs-up" },
        ]
    },
    {
        id: "windows",
        title: "النوافذ",
        icon: "fa-car-side",
        items: [
            { ar: "فتح النافذة اليمنى", cn: "打开右边车窗", icon: "fa-arrow-up-from-bracket" },
            { ar: "فتح النافذة اليسرى", cn: "打开左边车窗", icon: "fa-arrow-up-from-bracket" },
            { ar: "فتح الكل", cn: "把所有车窗打开", icon: "fa-up-right-and-down-left-from-center" },
            { ar: "غلق النافذة", cn: "关闭车窗", icon: "fa-arrow-down" },
            { ar: "فتح السقف", cn: "打开天窗", icon: "fa-cloud-sun" },
            { ar: "إغلاق السقف", cn: "关闭天窗", icon: "fa-cloud" },
            { ar: "فتح الصندوق", cn: "打开后备箱", icon: "fa-suitcase" },
            { ar: "الصندوق الأمامي", cn: "打开前备箱", icon: "fa-briefcase" },
            { ar: "فتح باب الوقود", cn: "打开油箱盖", icon: "fa-gas-pump" },
            { ar: "طوي المرايا", cn: "折叠后视镜", icon: "fa-compress" },
            { ar: "فرد المرايا", cn: "展开后视镜", icon: "fa-expand" },
        ]
    },
    {
        id: "climate",
        title: "المكيف",
        icon: "fa-wind",
        items: [
            { ar: "تشغيل المكيف", cn: "打开空调", icon: "fa-fan" },
            { ar: "إيقاف المكيف", cn: "关闭空调", icon: "fa-ban" },
            { ar: "20 درجة", cn: "把温度调到20度", icon: "fa-temperature-quarter" },
            { ar: "22 درجة", cn: "把温度调到22度", icon: "fa-temperature-half" },
            { ar: "24 درجة", cn: "把温度调到24度", icon: "fa-temperature-three-quarters" },
            { ar: "26 درجة", cn: "把温度调到26度", icon: "fa-temperature-full" },
            { ar: "أبرد", cn: "温度低一点", icon: "fa-snowflake" },
            { ar: "أدفأ", cn: "温度高一点", icon: "fa-fire" },
            { ar: "تدفئة المقعد", cn: "打开座椅加热", icon: "fa-fire" },
            { ar: "تهوية المقعد", cn: "打开座椅通风", icon: "fa-wind" },
            { ar: "تدفئة المقود", cn: "打开方向盘加热", icon: "fa-steering-wheel" },
        ]
    },
    {
        id: "seat",
        title: "المقاعد",
        icon: "fa-chair",
        items: [
            { ar: "وضع القيلولة", cn: "休息模式", icon: "fa-bed" },
            { ar: "وضع الجاذبية", cn: "打开零重力模式", icon: "fa-user-astronaut" },
            { ar: "تعديل الظهر", cn: "调直座椅", icon: "fa-arrows-up-down-left-right" },
            { ar: "تدليك المقعد", cn: "打开座椅按摩", icon: "fa-spa" },
            { ar: "إيقاف التدليك", cn: "关闭座椅按摩", icon: "fa-stop" },
        ]
    },
    {
        id: "nav",
        title: "الملاحة",
        icon: "fa-location-dot",
        items: [
            { ar: "الذهاب للمنزل", cn: "导航回家", icon: "fa-house" },
            { ar: "محطة شحن", cn: "导航到最近的充电站", icon: "fa-charging-station" },
            { ar: "بدء الملاحة", cn: "开始导航", icon: "fa-location-arrow" },
            { ar: "إلغاء الملاحة", cn: "结束导航", icon: "fa-ban" },
            { ar: "الطريق الأسرع", cn: "选择最快路线", icon: "fa-bolt" },
            { ar: "تجنب الطرق السريعة", cn: "避开高速公路", icon: "fa-road" },
        ]
    },
    {
        id: "media",
        title: "الترفيه",
        icon: "fa-music",
        items: [
            { ar: "تشغيل موسيقى", cn: "播放音乐", icon: "fa-music" },
            { ar: "إيقاف مؤقت", cn: "暂停音乐", icon: "fa-pause" },
            { ar: "المقطع التالي", cn: "下一首", icon: "fa-forward-step" },
            { ar: "السابق", cn: "上一首", icon: "fa-backward-step" },
            { ar: "رفع الصوت", cn: "声音大一点", icon: "fa-volume-high" },
            { ar: "تخفيض الصوت", cn: "声音小一点", icon: "fa-volume-low" },
            { ar: "كتم الصوت", cn: "静音", icon: "fa-volume-xmark" },
            { ar: "فتح دوين", cn: "打开抖音", icon: "fa-music" },
            { ar: "فتح بيليبيلي", cn: "打开哔哩哔哩", icon: "fa-tv" },
            { ar: "كوجو ميوزك", cn: "打开酷狗音乐", icon: "fa-headphones" },
            { ar: "فتح وي تشات", cn: "打开微信", icon: "fa-comment-dots" },
            { ar: "هيمالايا راديو", cn: "打开喜马拉雅", icon: "fa-radio" },
        ]
    },
    {
        id: "lights",
        title: "الإضاءة",
        icon: "fa-lightbulb",
        items: [
            { ar: "الإضاءة المحيطة", cn: "打开氛围灯", icon: "fa-lightbulb" },
            { ar: "إطفاء الإضاءة", cn: "关闭氛围灯", icon: "fa-moon" },
            { ar: "لون أزرق", cn: "把氛围灯调成蓝色", icon: "fa-circle" },
            { ar: "لون أبيض", cn: "把氛围灯调成白色", icon: "fa-circle" },
            { ar: "لون أحمر", cn: "把氛围灯调成红色", icon: "fa-circle" },
        ]
    },
    {
        id: "home",
        title: "البيت",
        icon: "fa-house-chimney",
        items: [
            { ar: "مكيف البيت", cn: "打开家里的空调", icon: "fa-house-chimney-window" },
            { ar: "إيقاف مكيف البيت", cn: "关闭家里的空调", icon: "fa-house-chimney" },
            { ar: "أضواء البيت", cn: "打开家里的灯", icon: "fa-lightbulb" },
        ]
    }
];

// بناء الواجهة
const tabsEl = document.getElementById('tabs');
const contentEl = document.getElementById('content');

categories.forEach((cat, idx) => {
    // تبويب
    const btn = document.createElement('button');
    btn.className = 'tab-btn' + (idx === 0 ? ' active' : '');
    btn.dataset.id = cat.id;
    btn.innerHTML = `<i class="fa-solid ${cat.icon}"></i> ${cat.title}`;
    btn.onclick = () => switchTab(cat.id);
    tabsEl.appendChild(btn);

    // قسم
    const sec = document.createElement('div');
    sec.className = 'section' + (idx === 0 ? ' active' : '');
    sec.id = 'sec-' + cat.id;

    const grid = document.createElement('div');
    grid.className = 'cmd-grid';

    cat.items.forEach(item => {
        const card = document.createElement('div');
        card.className = 'cmd-card';
        card.innerHTML = `
            <div class="cmd-icon"><i class="fa-solid ${item.icon}"></i></div>
            <div class="cmd-ar">${item.ar}</div>
            <div class="cmd-cn">${item.cn}</div>
        `;
        card.onclick = () => speakAndToast(item.cn, item.ar);
        grid.appendChild(card);
    });

    sec.appendChild(grid);
    contentEl.appendChild(sec);
});

function switchTab(id) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelector(`[data-id="${id}"]`).classList.add('active');
    document.getElementById('sec-' + id).classList.add('active');
    // تمرير التبويب للعرض
    document.querySelector(`[data-id="${id}"]`).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

// النطق + الإشعار
let toastTimer;
function speakAndToast(cn, ar) {
    // نطق صيني
    if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(cn);
        u.lang = 'zh-CN';
        u.rate = 0.9;
        u.pitch = 1;
        window.speechSynthesis.speak(u);
    }

    // تأثير بصري
    event.currentTarget && event.currentTarget.classList.add('speaking');
    setTimeout(() => {
        document.querySelectorAll('.cmd-card.speaking').forEach(el => el.classList.remove('speaking'));
    }, 700);

    // إشعار
    const toast = document.getElementById('toast');
    const toastText = document.getElementById('toast-text');
    toastText.textContent = cn + '  ·  ' + ar;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 2800);
}
</script>
